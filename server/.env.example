# PostgreSQL connection string (Neon / Supabase / local)
DATABASE_URL="postgresql://user:password@host:5432/incidentdesk?sslmode=require"

# Secret for signing JWTs — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret"

# How long an access token stays valid
JWT_EXPIRES_IN="7d"

# Frontend origin (for CORS). Local dev default below.
CLIENT_URL="http://localhost:5173"

# Server port
PORT=4000

# Node environment
NODE_ENV="development"
